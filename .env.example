# Sao chép thành file .env và điền giá trị (KHÔNG commit file .env)
# Gmail: bật xác thực 2 bước và tạo "Mật khẩu ứng dụng" cho MAIL_PASSWORD

SECRET_KEY=thay-bang-chuoi-ngau-nhien-dai

# PostgreSQL (bắt buộc). Ví dụ:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Kết nối dùng sslmode=require (máy chủ local không SSL có thể cần reverse proxy hoặc DB có SSL).
DATABASE_URL=

# Tài khoản admin duy nhất (username đăng nhập, không đăng ký trùng được)
ADMIN_USERNAME=admin
# Mật khẩu khi chạy: python createadmin.py (mặc định 123456 nếu bỏ trống)
ADMIN_INITIAL_PASSWORD=

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com

# Email nhận thông báo đơn hàng / liên hệ
ADMIN_EMAIL=your_email@gmail.com
